<resources>
    <!-- Tema base com a splash screen -->
    <style name="Theme.RayearthGames.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F0F0F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="postSplashScreenTheme">@style/Theme.RayearthGames</item>
    </style>

    <!-- Tema base do app (edge-to-edge escuro) -->
    <style name="Theme.RayearthGames" parent="android:Theme">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#0F0F0F</item>
    </style>
</resources>
